<?xml version="1.0" encoding="utf-8"?>
<!-- Backup rules for Android 11 and below -->
<full-backup-content>
    <!-- Include SharedPreferences (encryption key + wallet address) -->
    <include domain="sharedpref" path="." />
    <!-- Include all databases (XMTP SQLite) -->
    <include domain="database" path="." />
    <!-- Include internal files (XMTP may store data here) -->
    <include domain="file" path="." />
</full-backup-content>
